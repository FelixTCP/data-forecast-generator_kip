# Development environment template
# Copy to .env and fill in your values

# Anthropic Claude API key for LLM analysis
ANTHROPIC_API_KEY=sk-ant-...

# Output directory for generated artifacts
ARTIFACT_OUTPUT_DIR=./artifacts

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Model selection strategy for regression
# Options: simple, exhaustive, fast
MODEL_SELECTION_STRATEGY=simple

# Test mode (set to true to use mock LLM responses)
TEST_MODE=false
