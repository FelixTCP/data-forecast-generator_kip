# Development environment template
# Copy to .env and fill in your values

# GitHub OAuth token — required for the Copilot CLI inside the container.
# Get it by running on your host: gh auth login && gh auth token
# OAuth tokens (gho_...) are the only type supported by the Copilot CLI.
GH_TOKEN=gho_...

# Optional: override the Copilot model used by the pipeline
# COPILOT_MODEL=claude-haiku-4.5

# Output directory for generated artifacts
ARTIFACT_OUTPUT_DIR=./artifacts

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
